# ============================================
# MUMAA - RakshaTap by AlgoAura
# Environment Variables Configuration
# ============================================
#
# ⚠️  FOR NETLIFY DEPLOYMENT:
# Netlify does NOT read .env files!
# Set these variables in:
#   Netlify Dashboard → Site Settings → Environment Variables
#
# Copy each variable below and add it manually in the Netlify UI.
# ============================================

# ---- DATABASE (auto-managed on Netlify) ----
# On Netlify, SQLite auto-creates in /tmp. No setup needed.
# On local dev, this points to the local SQLite file:
DATABASE_URL="file:./db/custom.db"

# ---- AUTH (REQUIRED) ----
# Generate strong random secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this"
NEXTAUTH_SECRET="your-nextauth-secret-change-this"
NEXTAUTH_URL="http://localhost:3000"

# ---- EMAIL (Optional - for notifications) ----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ---- RAZORPAY PAYMENTS (Required for payments) ----
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# ---- TURN SERVER (Required for video calls) ----
TURN_URL="turn:your-turn-server.com:3478"
TURN_USERNAME="your-username"
TURN_CREDENTIAL="your-credential"

# ---- SEED (Optional) ----
SEED_SECRET="your-seed-secret"
