# ============================================
# MUMAA - RakshaTap by AlgoAura
# Environment Variables Configuration
# ============================================
#
# ⚠️  IMPORTANT FOR NETLIFY DEPLOYMENT:
# Netlify does NOT read .env files!
# You must set these variables in:
#   Netlify Dashboard → Site Settings → Environment Variables
#
# Copy each variable below and add it manually in the Netlify UI.
# For production, replace placeholder values with real ones.
# ============================================

# ---- DATABASE (REQUIRED) ----
# ⚠️ SQLite does NOT work on Netlify (ephemeral filesystem).
# You MUST use a cloud database for production:
#   - Neon PostgreSQL (free): https://neon.tech
#   - Supabase (free): https://supabase.com
#   - PlanetScale (free): https://planetscale.com
#
# For Neon PostgreSQL example:
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
#
# For local development (SQLite):
# DATABASE_URL="file:./db/custom.db"

# ---- AUTH (REQUIRED) ----
# Generate strong random secrets:
#   Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this"
NEXTAUTH_SECRET="your-nextauth-secret-change-this"
NEXTAUTH_URL="https://your-netlify-site.netlify.app"

# ---- EMAIL (Optional - for notifications) ----
# Gmail example: Use App Password from Google Account → Security → 2-Step Verification
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ---- RAZORPAY PAYMENTS (Required for payments) ----
# Get from: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# ---- TURN SERVER (Required for video calls) ----
# Free TURN: https://metered.ca/tools/openrelay
TURN_URL="turn:your-turn-server.com:3478"
TURN_USERNAME="your-username"
TURN_CREDENTIAL="your-credential"

# ---- SEED (Optional) ----
SEED_SECRET="your-seed-secret"
